{
  "name": "@honlnk/image-studio-companion",
  "version": "0.6.1",
  "description": "Local CLI companion for GPT Image Studio image API credential proxying.",
  "type": "module",
  "bin": {
    "gpt-image-studio": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/honlnk/gpt-image-studio.git",
    "directory": "companion"
  },
  "keywords": [
    "gpt-image-studio",
    "openai",
    "images",
    "cli",
    "companion"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/main.ts serve --channel dev",
    "prepack": "pnpm build",
    "build": "tsc",
    "serve": "node dist/main.js serve",
    "serve:dev": "node dist/main.js serve --channel dev",
    "start": "node dist/main.js start",
    "start:dev": "node dist/main.js start --channel dev",
    "stop": "node dist/main.js stop",
    "restart": "node dist/main.js restart",
    "pair": "node dist/main.js pair",
    "logs": "node dist/main.js logs",
    "status": "node dist/main.js status",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "commander": "^13.1.0",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3"
  }
}
