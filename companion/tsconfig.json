{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@gpt-image-studio/protocol": ["../packages/protocol/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
