{
  "name": "gpt-image-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "vite",
    "dev:companion": "pnpm --filter @honlnk/image-studio-companion dev",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
